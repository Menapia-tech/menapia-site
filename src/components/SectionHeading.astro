---
interface Props {
  tag?: string;
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
}

const { tag, title, subtitle, align = 'left' } = Astro.props;
---

<div class:list={[align === 'center' && 'text-center']}>
  {tag && (
    <p class="text-atmos-400 text-sm font-medium tracking-wide uppercase mb-3">
      {tag}
    </p>
  )}
  <h2 class="text-3xl sm:text-4xl font-bold text-white tracking-tight">
    {title}
  </h2>
  {subtitle && (
    <p class:list={[
      'mt-4 text-lg text-slate-400 leading-relaxed',
      align === 'center' ? 'max-w-2xl mx-auto' : 'max-w-2xl',
    ]}>
      {subtitle}
    </p>
  )}
</div>
