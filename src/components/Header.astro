---
const navItems = [
  { label: 'Home', href: '/menapia-site/' },
  { label: 'Projects', href: '/menapia-site/projects/' },
  { label: 'Forecast Partners', href: '/menapia-site/forecast-partners/' },
  { label: 'Platform', href: '/menapia-site/platform/' },
  { label: 'Data', href: '/menapia-site/data/' },
  { label: 'About', href: '/menapia-site/about/' },
  { label: 'Contact', href: '/menapia-site/contact/' },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 glass">
  <nav class="container-wide section-padding" aria-label="Primary navigation">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a
        href="/menapia-site/"
        class="flex items-center gap-2 text-white font-semibold text-lg tracking-tight hover:text-atmos-400 transition-colors"
        aria-label="Menapia — Home"
      >
        <img
          src="/menapia-site/logo.png"
          alt="Menapia"
          width="120"
          height="36"
          class="h-8 w-auto"
        />
      </a>

      <!-- Desktop navigation -->
      <ul class="hidden lg:flex items-center gap-1" role="list">
        {navItems.map(({ label, href }) => {
          const isActive = currentPath === href || (href !== '/menapia-site/' && currentPath.startsWith(href));
          return (
            <li>
              <a
                href={href}
                class:list={[
                  'px-3 py-2 rounded-lg text-sm font-medium transition-colors',
                  isActive
                    ? 'text-atmos-400 bg-atmos-950/50'
                    : 'text-slate-300 hover:text-white hover:bg-slate-800/50',
                ]}
                aria-current={isActive ? 'page' : undefined}
              >
                {label}
              </a>
            </li>
          );
        })}
      </ul>

      <!-- Mobile menu button -->
      <button
        type="button"
        class="lg:hidden p-2 rounded-lg text-slate-300 hover:text-white hover:bg-slate-800/50 transition-colors"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open navigation menu"
        id="mobile-menu-btn"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="lg:hidden hidden pb-4" role="navigation" aria-label="Mobile navigation">
      <ul class="flex flex-col gap-1 pt-2 border-t border-slate-700/50" role="list">
        {navItems.map(({ label, href }) => {
          const isActive = currentPath === href || (href !== '/menapia-site/' && currentPath.startsWith(href));
          return (
            <li>
              <a
                href={href}
                class:list={[
                  'block px-3 py-2 rounded-lg text-sm font-medium transition-colors',
                  isActive
                    ? 'text-atmos-400 bg-atmos-950/50'
                    : 'text-slate-300 hover:text-white hover:bg-slate-800/50',
                ]}
                aria-current={isActive ? 'page' : undefined}
              >
                {label}
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
    btn.setAttribute('aria-label', expanded ? 'Open navigation menu' : 'Close navigation menu');
  });
</script>
