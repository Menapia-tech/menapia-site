---
interface Props {
  title: string;
  programme: string;
  role: string;
  status: string;
  summary: string;
  externalUrl?: string;
  tags: string[];
  slug: string;
}

const { title, programme, role, status, summary, externalUrl, tags, slug } = Astro.props;

const statusColour: Record<string, string> = {
  active: 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20',
  completed: 'bg-slate-500/10 text-slate-400 border-slate-500/20',
  planned: 'bg-amber-500/10 text-amber-400 border-amber-500/20',
};
---

<article class="glass rounded-2xl p-6 sm:p-8 flex flex-col h-full hover:border-atmos-700/50 transition-colors">
  <div class="flex items-start justify-between gap-4 mb-4">
    <div>
      <p class="text-atmos-400 text-xs font-medium uppercase tracking-wider mb-1">{programme}</p>
      <h3 class="text-white font-bold text-xl">{title}</h3>
    </div>
    <span class:list={['shrink-0 px-2.5 py-1 text-xs font-medium rounded-full border', statusColour[status] ?? statusColour.planned]}>
      {status}
    </span>
  </div>

  <p class="text-slate-400 text-sm leading-relaxed mb-4 flex-1">{summary}</p>

  <div class="flex flex-wrap gap-2 mb-4">
    <span class="text-xs text-slate-500 font-medium">{role}</span>
  </div>

  <div class="flex flex-wrap gap-1.5">
    {tags.map((tag) => (
      <span class="px-2 py-0.5 text-xs text-slate-500 bg-slate-800/50 rounded-md">{tag}</span>
    ))}
  </div>

  {externalUrl && (
    <a
      href={externalUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-4 inline-flex items-center gap-1.5 text-sm text-atmos-400 hover:text-atmos-300 transition-colors"
    >
      Learn more
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
      </svg>
    </a>
  )}
</article>
