---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
---

<BaseLayout
  title="Platform"
  description="Menapia's vertically profiling multicopter platform — routine atmospheric profiles, calibrated payloads, and network-scale deployment."
>
  <section class="pt-32 pb-20 sm:pt-40 sm:pb-28">
    <div class="container-wide section-padding">
      <SectionHeading
        tag="Platform"
        title="Vertically profiling multicopter capability"
        subtitle="Purpose-built for routine atmospheric observation. Our platform combines multicopter endurance with calibrated meteorological payloads to deliver consistent, high-quality vertical profiles."
      />
    </div>
  </section>

  <!-- Core capabilities -->
  <section class="py-20 border-t border-slate-800/50">
    <div class="container-wide section-padding">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="glass rounded-2xl p-6 sm:p-8">
          <h3 class="text-white font-semibold text-lg mb-3">Routine vertical profiles</h3>
          <p class="text-slate-400 text-sm leading-relaxed">
            Our systems are designed for sustained, repeatable operation. Profiles are collected on schedule
            across weather conditions, building the consistent observational records that forecasting
            and research programmes require.
          </p>
        </div>

        <div class="glass rounded-2xl p-6 sm:p-8">
          <h3 class="text-white font-semibold text-lg mb-3">Calibration and traceability</h3>
          <p class="text-slate-400 text-sm leading-relaxed">
            Every sensor is calibrated and traceable. We maintain rigorous calibration schedules and
            documentation so that observations meet the standards expected by meteorological
            data users and research collaborators.
          </p>
        </div>

        <div class="glass rounded-2xl p-6 sm:p-8">
          <h3 class="text-white font-semibold text-lg mb-3">Payload integration</h3>
          <p class="text-slate-400 text-sm leading-relaxed">
            The platform supports a range of meteorological payloads — temperature, humidity, pressure,
            wind — integrated to provide complete atmospheric column measurements from the surface
            upward through the boundary layer.
          </p>
        </div>

        <div class="glass rounded-2xl p-6 sm:p-8">
          <h3 class="text-white font-semibold text-lg mb-3">Network deployments</h3>
          <p class="text-slate-400 text-sm leading-relaxed">
            Designed for multi-site operation. Our systems can be deployed as coordinated networks,
            providing spatially distributed observations that capture atmospheric variability
            across a region rather than a single point.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Operational design -->
  <section class="py-20 border-t border-slate-800/50">
    <div class="container-wide section-padding">
      <SectionHeading
        tag="Design philosophy"
        title="Built for operations"
        subtitle="Every aspect of the platform is optimised for reliable, repeatable atmospheric observation."
      />

      <div class="mt-10 max-w-2xl space-y-6">
        <div class="flex gap-4 items-start">
          <div class="shrink-0 w-2 h-2 rounded-full bg-atmos-500 mt-2"></div>
          <div>
            <p class="text-slate-300 text-sm leading-relaxed">
              <strong class="text-white">Operational resilience</strong> — systems designed to operate in a wide range of weather conditions with minimal downtime.
            </p>
          </div>
        </div>
        <div class="flex gap-4 items-start">
          <div class="shrink-0 w-2 h-2 rounded-full bg-atmos-500 mt-2"></div>
          <div>
            <p class="text-slate-300 text-sm leading-relaxed">
              <strong class="text-white">Data integrity</strong> — end-to-end quality control from sensor to delivery, with full metadata provenance.
            </p>
          </div>
        </div>
        <div class="flex gap-4 items-start">
          <div class="shrink-0 w-2 h-2 rounded-full bg-atmos-500 mt-2"></div>
          <div>
            <p class="text-slate-300 text-sm leading-relaxed">
              <strong class="text-white">Scalable architecture</strong> — the same platform and processes that run one site can be extended to a multi-site network.
            </p>
          </div>
        </div>
        <div class="flex gap-4 items-start">
          <div class="shrink-0 w-2 h-2 rounded-full bg-atmos-500 mt-2"></div>
          <div>
            <p class="text-slate-300 text-sm leading-relaxed">
              <strong class="text-white">Standards alignment</strong> — observations are collected and encoded to meet WMO and meteorological community expectations.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 border-t border-slate-800/50">
    <div class="container-narrow section-padding text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-white">Discuss deployment options</h2>
      <p class="mt-3 text-slate-400 max-w-lg mx-auto">
        Whether you need a single-site evaluation or a multi-site network, we can discuss how our platform fits your requirements.
      </p>
      <a
        href="/menapia-site/contact/"
        class="mt-6 inline-block px-6 py-3 bg-atmos-600 hover:bg-atmos-500 text-white font-medium rounded-xl transition-colors text-sm"
      >
        Talk to us
      </a>
    </div>
  </section>
</BaseLayout>
